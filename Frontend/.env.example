# ──────────────────────────────────────────
# UniCampus Frontend — Environment Variables
# ──────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit the actual .env file to version control.
# ──────────────────────────────────────────
# Vite requires the VITE_ prefix for all client-side env vars.
# These are PUBLIC config values — they identify the Firebase project
# but do NOT grant privileged access. Firebase Security Rules protect data.

# ── Firebase Client SDK ──
# Get these from: Firebase Console → Project Settings → General → Your Apps
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ── Backend API URL ──
VITE_API_URL=http://localhost:5000/api/v1

# ── App URL (for Firebase email verification redirect) ──
VITE_APP_URL=http://localhost:5173
