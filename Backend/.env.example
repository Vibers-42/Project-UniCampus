# ═══════════════════════════════════════════════
# UniCampus Backend — Environment Variables
# ═══════════════════════════════════════════════
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file to version control.
# ═══════════════════════════════════════════════

# ───── Server ─────
NODE_ENV=development
PORT=5000

# ───── Database (REQUIRED) ─────
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>

# ───── Firebase Admin SDK (REQUIRED) ─────
# Get these from Firebase Console → Project Settings → Service Accounts
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ───── Cloudinary (RECOMMENDED) ─────
# Required for image/PDF uploads. Get from Cloudinary Dashboard.
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ───── CORS / Frontend URL ─────
# Set to your frontend deployment URL in production.
CLIENT_URL=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# ───── AI Chatbot (OPTIONAL) ─────
# Groq API key for the AI Doubt Solver feature.
# If not set, AI features degrade gracefully.
GROQ_API_KEY=gsk_your_groq_api_key

# ───── Email / Nodemailer (OPTIONAL) ─────
# Required only for email notifications. Auth uses Firebase.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# ───── JWT (RESERVED — not currently used) ─────
# Firebase handles auth tokens. Reserved for future internal tokens.
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
