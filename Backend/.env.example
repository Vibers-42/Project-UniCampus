# ──────────────────────────────────────────
# UniCampus Backend — Environment Variables
# ──────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit the actual .env file to version control.
# ──────────────────────────────────────────

# ── Server ──
PORT=5000
NODE_ENV=development

# ── Database ──
# Get your connection string from MongoDB Atlas → Connect → Drivers
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# ── Frontend URL (for CORS) ──
CLIENT_URL=http://localhost:5173

# ── JWT (reserved for future use) ──
# Firebase handles primary authentication. These are reserved for
# potential future features (invitation links, internal service tokens, etc.).
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ── Firebase Admin SDK ──
# Service account credentials for server-side token verification.
# Get these from: Firebase Console → Project Settings → Service Accounts → Generate Key
#
# IMPORTANT: The private key must be on ONE LINE with literal \n characters
# (not actual newlines). Wrap the entire key in double quotes in .env.
# Example:
#   FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvg...\n-----END PRIVATE KEY-----\n"
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ── Cloudinary ──
# For avatar uploads and media storage.
# Get these from: https://console.cloudinary.com/settings
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Email (Nodemailer — for notifications) ──
# Used for platform notifications (NOT for auth — Firebase handles verification).
# Configure with your email provider (Gmail, SendGrid, Mailtrap, etc.)
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=

# ── LLM / AI Chatbot ──
# Provider: 'openai', 'claude', or 'gemini'
LLM_PROVIDER=
LLM_API_KEY=
