# ──────────────────────────────────────────
# UniCampus Backend — Environment Variables
# ──────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit the actual .env file to version control.
# ──────────────────────────────────────────

# ── Server ──
PORT=5000
NODE_ENV=development

# ── Database ──
# Get your connection string from MongoDB Atlas → Connect → Drivers
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# ── CORS ──
# Frontend URL(s) allowed to call this API
# Use * for development, specific origin(s) for production
CORS_ORIGIN=*

# ── JWT (used after auth module is built) ──
JWT_SECRET=your_jwt_secret_here_change_this
JWT_EXPIRY=7d

# ── Cloudinary ──
# ARCHITECTURE NOTE:
#   Backend handles JSON + business logic only.
#   Binary file uploads go directly from the frontend to Cloudinary
#   using the unsigned upload preset.
#   MongoDB stores only metadata + Cloudinary URLs — never binary files.
#
# Get these from: https://console.cloudinary.com/settings
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_UPLOAD_PRESET=your_unsigned_upload_preset_name
