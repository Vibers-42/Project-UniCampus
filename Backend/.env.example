# ──────────────────────────────────────────
# UniCampus Backend — Environment Variables
# ──────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit the actual .env file to version control.
# ──────────────────────────────────────────

# ── Server ──
PORT=5000
NODE_ENV=development

# ── Database ──
# Get your connection string from MongoDB Atlas → Connect → Drivers
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# ── Frontend URL (for CORS) ──
CLIENT_URL=http://localhost:5173

# ── JWT ──
# Two separate secrets for access and refresh tokens.
# Generate strong secrets: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ── Cloudinary ──
# ARCHITECTURE NOTE:
#   Backend handles JSON + business logic only.
#   Binary file uploads go directly from the frontend to Cloudinary.
#   MongoDB stores only metadata + Cloudinary URLs — never binary files.
#
# Get these from: https://console.cloudinary.com/settings
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Email (Nodemailer — for OTP delivery) ──
# Configure with your email provider (Gmail, SendGrid, Mailtrap, etc.)
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=

# ── LLM / AI Chatbot ──
# Provider: 'openai', 'claude', or 'gemini'
LLM_PROVIDER=
LLM_API_KEY=
